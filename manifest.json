{
  "manifest_version": 3,
  "name": "LazyFill",
  "description": "Auto-fills form fields on any web page with one click.",
  "version": "1.0.0",
  "permissions": ["activeTab", "scripting"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["data/test-data.json", "data/field-config.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
